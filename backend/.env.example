# Environment Configuration
# Copy to .env and fill in your actual values

# App Settings
DEBUG=False
APP_NAME="AI Business Idea Validator"
APP_VERSION="1.0.0"

# Database Settings
DATABASE_URL=postgresql://user:password@localhost:5432/ai_validator_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# API Settings
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI Settings
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Logging
LOG_LEVEL=INFO
